// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "format_on_save": "off",
  "icon_theme": {
    "mode": "dark",
    "light": "VSCode Icons for Zed (Dark)",
    "dark": "VSCode Icons for Zed (Dark)",
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "languages": {
    "XML": {
      "formatter": {
        "external": {
          "command": "powershell",
          "arguments": [
            "-ExecutionPolicy",
            "Bypass",
            "-File",
            "C:\\tools\\Zed XML Formatter\\xmlfmt.ps1",
          ],
        },
      },
    },
  },
  "file_types": {
    "html": ["*.mustache", "*.liquid"],
    "Markdown": ["txt"],
  },
  "linked_edits": true,
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "high",
      },
      "type": "registry",
    },
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "terminal": {
    "font_family": "CaskaydiaCove Nerd Font",
    "font_size": 12.0,
  },
}
